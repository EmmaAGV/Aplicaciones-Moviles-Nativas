<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/mainFragment">

    <fragment
        android:id="@+id/mainFragment"
        android:name="com.example.routinepro.MainFragment"
        android:label="Encuesta"
        tools:layout="@layout/fragment_main" >
        <action
            android:id="@+id/action_mainFragment_to_dashboardFragment"
            app:destination="@id/dashboardFragment" />
    </fragment>

    <fragment
        android:id="@+id/dashboardFragment"
        android:name="com.example.routinepro.DashboardFragment"
        android:label="Dashboard"
        tools:layout="@layout/fragment_dashboard" >
        <action
            android:id="@+id/action_dashboardFragment_to_statisticsFragment"
            app:destination="@id/statisticsFragment" />
        <action
            android:id="@+id/action_dashboardFragment_to_exploreFragment"
            app:destination="@id/exploreFragment" />
        <action
            android:id="@+id/action_dashboardFragment_to_workoutPlayerFragment"
            app:destination="@id/workoutPlayerFragment" />
        <action
            android:id="@+id/action_dashboardFragment_to_nutritionDetailFragment"
            app:destination="@id/nutritionDetailFragment" />
    </fragment>

    <fragment
        android:id="@+id/exploreFragment"
        android:name="com.example.routinepro.ExploreFragment"
        android:label="Explorar"
        tools:layout="@layout/fragment_explore" >
        <action
            android:id="@+id/action_exploreFragment_to_workoutPlayerFragment"
            app:destination="@id/workoutPlayerFragment" />
        <action
            android:id="@+id/action_exploreFragment_to_nutritionDetailFragment"
            app:destination="@id/nutritionDetailFragment" />
    </fragment>

    <fragment
        android:id="@+id/statisticsFragment"
        android:name="com.example.routinepro.StatisticsFragment"
        android:label="Estadísticas"
        tools:layout="@layout/fragment_statistics" />

    <fragment
        android:id="@+id/profileFragment"
        android:name="com.example.routinepro.ProfileFragment"
        android:label="Perfil"
        tools:layout="@layout/fragment_profile" />

    <fragment
        android:id="@+id/workoutPlayerFragment"
        android:name="com.example.routinepro.WorkoutPlayerFragment"
        android:label="Entrenamiento"
        tools:layout="@layout/fragment_workout_player" />

    <fragment
        android:id="@+id/nutritionDetailFragment"
        android:name="com.example.routinepro.NutritionDetailFragment"
        android:label="Guía Nutricional"
        tools:layout="@layout/fragment_nutrition_detail" />

</navigation>
